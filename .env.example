# Copy to .env and fill. .env is gitignored (repo is public — never commit real values).

# ── Xero (Custom Connection — FREE on the Demo Company) ─────────────────────
# developer.xero.com → New app → "Custom connection" → pick scopes →
# authorise on Demo Company (region UK) → copy the two values below (secret shown once).
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# LEAVE EMPTY. A client-credentials Custom Connection must request the token with NO
# scope — the umbrella auth-code scopes below fail with invalid_scope. With scope empty,
# Xero mints a token carrying the connection's own granular scopes (invoices,
# banktransactions, payments, contacts, settings, reports.*). The xero-mcp-server
# subprocess also treats an empty XERO_SCOPES as "unset" and auto-selects granular scopes.
XERO_SCOPES=
# (For reference only — do NOT set these; the connection grants them automatically:)
# accounting.invoices accounting.banktransactions accounting.payments accounting.contacts
# accounting.settings accounting.reports.trialbalance.read accounting.reports.balancesheet.read
# accounting.reports.profitandloss.read accounting.reports.aged.read accounting.attachments

# ── Make MCP (only if building on Make) ─────────────────────────────────────
# Make → your name (top-right) → Profile → API access → Add token → scope: mcp:use.
# Then your connection URL (confirm exact zone/path on the token page):
#   https://<zone>.make.com/mcp/api/v1/u/<MCP_TOKEN>/sse
MAKE_MCP_URL=

# ── CORS (Make scenario / ngrok exposure) ────────────────────────────────────
# Comma-separated allowed origins.  Leave blank for localhost-only (default).
# During demo, set to * (or your ngrok URL) so Make's HTTP module can reach the backend.
# Example:  CORS_ALLOW_ORIGINS=*
# Example:  CORS_ALLOW_ORIGINS=https://abc123.ngrok.io,http://localhost:5173
CORS_ALLOW_ORIGINS=

# ── Lovable ──  no key here; connect via the Claude Code plugin (OAuth). See docs/SETUP.md.
# ── Replit ──  no key here; import this GitHub repo into Replit to run/host. See docs/SETUP.md.
