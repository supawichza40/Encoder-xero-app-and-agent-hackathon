# Copy to .env (gitignored) and fill in the real value. NEVER commit the real key.
#
# Team-scoped BimpeAI API key (sk_ prefix). Server-side only — the browser never sees it.
# Used by server.mjs (/api/status polling) and provision.sh (agent creation + smoke test).
BIMPEAI_API_KEY=sk_xxx

# The VAT Guardian agent id, printed by provision.sh after it creates the agent.
# NOT a secret (safe to commit if you prefer) — it just tells /api/status which agent to poll.
VAT_GUARDIAN_AGENT_ID=PASTE_AGENT_ID_HERE
